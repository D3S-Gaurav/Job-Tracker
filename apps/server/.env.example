# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://admin:password@localhost:5432/saas_db?schema=public"

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-64-chars-long-change-in-production"

# ─── Role Encryption (AES-256-GCM) ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROLE_ENCRYPTION_KEY="your-64-hex-char-key-here-generate-with-command-above"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
